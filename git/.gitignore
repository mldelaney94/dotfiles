# Global excludes (core.excludesFile → ~/.gitignore)
# Only never-commit OS/editor/tool debris. Language builds, deps, and
# secrets belong in each repo's .gitignore — not here.

# --- macOS ---
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk
__MACOSX/

# --- Windows ---
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
[Dd]esktop.ini
$RECYCLE.BIN/
*.stackdump

# --- Linux ---
.fuse_hidden*
.directory
.Trash-*
.nfs*
nohup.out

# --- Vim ---
[._]*.s[a-v][a-z]
# don't ignore svg specifically, even though the above rule can match it sometimes
!*.svg
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]
Session.vim
Sessionx.vim
.netrwhist
*~
# ctags / etags (drop `tags` if a project tracks a file by that name)
tags
TAGS
[._]*.un~

# --- Emacs ---
\#*\#
.\#*

# --- Merge / patch leftovers ---
*.orig
*.rej
*.BACKUP.*
*.BASE.*
*.LOCAL.*
*.REMOTE.*

# --- Editor local state (not shared project config) ---
.history/
*.code-workspace
