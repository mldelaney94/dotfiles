[alias]
  au = add -u
  cm = commit -m
  cb = checkout -b
  rc = rebase --continue
  lg = log --pretty=format:\"%C(auto)%h %C(auto)%an - %cr %d%n%s%n\"
[core]
  excludesFile = ~/.gitignore
[pull]
  # Rebase local commits onto the upstream branch instead of merging
  rebase = true
[push]
  # Push only the current branch to its upstream (not all matching branches)
  default = current
  # On first push, create the remote branch and set upstream tracking
  autoSetupRemote = true
[user]
  email =
  name =
  # Personal access token used for authenticated Git operations
  password = pat_token
[credential]
  # Store credentials in the macOS Keychain
  helper = osxkeychain
[credential]
  # Use GitHub CLI to supply credentials for GitHub remotes
  helper = !/usr/local/gh/bin/gh auth git-credential
